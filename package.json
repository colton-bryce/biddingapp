{
  "name": "silent-auction",
  "version": "1.0.0",
  "description": "Silent auction management app",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"cd client && npm run dev\"",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
